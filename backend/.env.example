# Configuration pour développement local
# Copier ce fichier en .env.local dans le répertoire backend

# === BASE DE DONNÉES ===
# Option 1: URL complète (pour Railway)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/edu_db

# Option 2: Paramètres individuels (pour développement local)
DB_HOST=localhost
DB_PORT=5432
DB_USER=edu_user
DB_PASSWORD=edu_password
DB_NAME=edu_db

# === SÉCURITÉ ===
# Générer avec: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# === ENVIRONNEMENT ===
NODE_ENV=development
PORT=3000

# === CORS ===
# L'URL de votre frontend (pour CORS)
# Développement:
FRONTEND_URL=http://localhost:3000

# Production (remplacer par votre URL Vercel):
# FRONTEND_URL=https://your-app.vercel.app
